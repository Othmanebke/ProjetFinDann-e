generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum OAuthProvider {
  GOOGLE
  GITHUB
  MICROSOFT
  STRAVA
  LOCAL
}

enum WorkoutType {
  RUN
  WALK
  CYCLE
  GYM
  HIIT
  YOGA
  SWIM
}

enum RouteType {
  RUNNING
  WALKING
  CYCLING
}

enum RouteDifficulty {
  EASY
  MODERATE
  HARD
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  ENDURANCE
  FLEXIBILITY
  MAINTENANCE
}

enum SubscriptionPlan {
  FREE
  PREMIUM_COACH
  PASS_VOYAGEUR
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String?
  avatarUrl         String?
  role              Role           @default(USER)
  oauthProvider     OAuthProvider?
  oauthProviderId   String?
  passwordHash      String?
  phone             String?
  timezone          String         @default("Europe/Paris")
  isActive          Boolean        @default(true)
  emailVerified     Boolean        @default(false)
  lastLoginAt       DateTime?

  // Fitness profile
  fitnessGoal       FitnessGoal?
  weightKg          Float?
  heightCm          Float?
  weeklyTargetKm    Float?         @default(20)
  preferredActivities WorkoutType[] @default([RUN, WALK])

  // Current location (for route generation)
  currentCity       String?
  currentCountry    String?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  workouts          Workout[]
  travelRoutes      TravelRoute[]
  nutritionLogs     NutritionLog[]
  subscription      Subscription?
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  fitChats          FitChat[]
  activityLogs      ActivityLog[]

  @@index([email])
  @@index([oauthProvider, oauthProviderId])
}

model RefreshToken {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?

  @@index([token])
  @@index([userId])
}

model Workout {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          WorkoutType @default(RUN)
  title         String?

  // Performance metrics (for week-over-week comparison)
  distanceKm    Float       @default(0)
  durationMin   Int         @default(0)
  calories      Int         @default(0)
  heartRateAvg  Int?
  heartRateMax  Int?
  paceMinPerKm  Float?      // min/km for runs
  elevationM    Float?      @default(0)

  // Location
  city          String?
  country       String?
  routeId       String?
  route         TravelRoute? @relation(fields: [routeId], references: [id])

  // Time tracking for weekly comparison
  completedAt   DateTime    @default(now())
  weekNumber    Int         // ISO week number 1-53
  yearNumber    Int

  notes         String?
  isOutdoor     Boolean     @default(true)
  weatherInfo   Json?       // { temp, condition, humidity }

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, weekNumber, yearNumber])
  @@index([userId, completedAt])
}

model TravelRoute {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  city            String
  country         String
  name            String
  description     String?

  type            RouteType       @default(RUNNING)
  difficulty      RouteDifficulty @default(MODERATE)

  distanceKm      Float
  estimatedMinutes Int
  elevationM      Float?          @default(0)

  // AI-generated route data
  waypoints       Json            // Array of { lat, lng, name, type }
  pointsOfInterest Json           // Array of { name, type, description }
  aiGenerated     Boolean         @default(true)
  aiPromptUsed    String?

  // Safety info
  safetyScore     Int?            @default(8) // 1-10
  safetyNotes     String?
  bestTimeOfDay   String?         // "morning", "evening"

  isPublic        Boolean         @default(false)
  savedCount      Int             @default(0)

  workouts        Workout[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([userId])
  @@index([city, country])
}

model NutritionLog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  city          String?
  country       String?
  restaurant    String?
  mealName      String
  description   String?

  // Macros
  caloriesKcal  Int
  proteinG      Float     @default(0)
  carbsG        Float     @default(0)
  fatG          Float     @default(0)
  fiberG        Float?

  // AI recommendation context
  aiRecommended Boolean   @default(false)
  tags          String[]  @default([])  // ["local", "high-protein", "vegan"]

  loggedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@index([userId, loggedAt])
}

model ActivityLog {
  id          String    @id @default(cuid())
  action      String
  metadata    Json?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  stripePriceId         String?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  trialEnd              DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([stripeCustomerId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean   @default(false)
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
}

model FitChat {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String       @default("Nouvelle conversation")
  messages  FitMessage[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
}

model FitMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      FitChat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant"
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([chatId])
}
